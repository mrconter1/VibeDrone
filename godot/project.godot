; Godot 4 project (C#). Open this folder in Godot 4.x .NET edition.

config_version=5

[application]

config/name="OpenDrone"
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.3", "C#", "Forward Plus")

; No engine boot splash: hide the Godot logo and paint the boot window our own dark
; colour so the very first frame already matches the loading screen - no Godot branding,
; no white flash, straight into our own LoadingScreen.
boot_splash/show_image=false
boot_splash/bg_color=Color(0.02, 0.025, 0.03, 1)

[display]

; Open fullscreen on the very first frame (not a small window that then jumps to
; fullscreen once _Ready runs) so boot goes straight into our dark loading screen.
window/size/mode=3
window/size/borderless=true

[dotnet]

project/assembly_name="OpenDrone"

[input_devices]

pointing/emulate_touch_from_mouse=false

[rendering]

; Default to the D3D12 backend on Windows. The AMD Radeon 740M iGPU intermittently
; segfaults inside the Vulkan driver at startup; D3D12 sidesteps that path entirely and
; runs the Forward+ renderer cleanly. Other platforms keep their default (Vulkan).
rendering_device/driver.windows="d3d12"

[physics]

; 250 Hz flight-model tick (4 ms): input sampled and transform updated every 4 ms
; instead of 16.7 ms -> lower stick-to-photon latency, smoother high-refresh motion.
; The model is ~100 flops/step; this is nowhere near a CPU cost.
common/physics_ticks_per_second=250
; interpolate node transforms between physics ticks for refresh rates beyond 250 Hz
; and to hide tick/frame beat frequencies.
common/physics_interpolation=true
